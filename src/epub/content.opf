		<meta property="title-type" refines="#subtitle">subtitle</meta>
		<dc:title id="fulltitle">Cakes and Ale; or, The Skeleton in the Cupboard</dc:title>
		<meta property="file-as" refines="#fulltitle">Cakes and Ale</meta>
		<meta property="title-type" refines="#fulltitle">extended</meta>
